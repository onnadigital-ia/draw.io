        <mxCell id="501" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacing=10;" value="&lt;b&gt;1. Briefing (Toma de Requisitos)&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;font-size:11px;&quot;&gt;Resumen estructurado de necesidades.&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#666666;&quot;&gt;💡 Tip: No asumas nada. Usa las palabras exactas del cliente.&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="260" x="660" y="130" as="geometry" />
        </mxCell>
        <mxCell id="Szt3vnFu08vihGEeEnuN-621" edge="1" parent="1" source="502" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;html=1;strokeColor=#666666;endArrow=classic;endFill=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;exitPerimeter=0;" target="Szt3vnFu08vihGEeEnuN-615">

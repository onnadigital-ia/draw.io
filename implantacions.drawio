        <mxCell id="502" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacing=10;" value="&lt;b&gt;2. Registro de Credenciales&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;font-size:11px;&quot;&gt;Accesos a servidores, APIs o bases de datos.&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#666666;&quot;&gt;💡 Tip: Usa un gestor de contraseñas, nunca las guardes en texto plano.&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="260" x="660" y="230" as="geometry" />
        </mxCell>
        <mxCell id="Szt3vnFu08vihGEeEnuN-622" edge="1" parent="1" source="503" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;html=1;strokeColor=#666666;endArrow=classic;endFill=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;exitPerimeter=0;" target="Szt3vnFu08vihGEeEnuN-615">

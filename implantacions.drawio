        <mxCell id="503" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacing=10;" value="&lt;b&gt;3. Alcance y Propuesta (SoW)&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;font-size:11px;&quot;&gt;Presupuesto, hitos y entregables.&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#666666;&quot;&gt;💡 Tip: Define claramente el &quot;Fuera de Alcance&quot; para evitar problemas.&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="260" x="660" y="330" as="geometry" />
        </mxCell>
        <mxCell id="504" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacing=10;" value="&lt;b&gt;4. Diagrama de Arquitectura&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;font-size:11px;&quot;&gt;Mapa visual de conexiones (n8n, APIs).&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#666666;&quot;&gt;💡 Tip: Haz una versión técnica y otra simple para el cliente.&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="260" x="660" y="630" as="geometry" />
        </mxCell>
        <mxCell id="505" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacing=10;" value="&lt;b&gt;5. Backlog de Tareas&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;font-size:11px;&quot;&gt;Listado de tareas técnicas asignadas.&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#666666;&quot;&gt;💡 Tip: Regla de las 8h. Si una tarea tarda más, divídela en dos.&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="260" x="660" y="730" as="geometry" />
        </mxCell>
        <mxCell id="506" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacing=10;" value="&lt;b&gt;6. Documentación de Código&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;font-size:11px;&quot;&gt;Instrucciones (README), endpoints, variables.&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#666666;&quot;&gt;💡 Tip: Escribe pensando en el programador que lo leerá en 1 año.&lt;/i&gt;&lt;/div&gt;" vertex="1">
